<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:id="@+id/fragment_home_staff"
    android:layout_height="match_parent"
    tools:context="dashboard_fragment.HomeFragment_staff">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/gradient_blue_bg" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bảng quản trị"
                            android:textColor="#FFFFFF"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chào mừng, "
                            android:textColor="#D1E9FF"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_alignParentRight="true"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="4dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/dashboard_icon_avatar" />
                    </com.google.android.material.card.MaterialCardView>
                </RelativeLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/app_secondary_text_color" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:gravity="center_vertical|start"
                            android:text="TẠO PHIẾU KHÁM"
                            android:textColor="@color/app_primary_text_color"
                            app:icon="@drawable/dashboard_icon_doctor"
                            app:iconPadding="16dp"
                            app:iconTint="@color/app_primary_color" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/app_secondary_text_color" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:gravity="center_vertical|start"
                            android:text="QUẢN LÝ PHIẾU KHÁM"
                            android:textColor="@color/app_primary_text_color"
                            app:icon="@drawable/dashboard_icon_clinic"
                            app:iconPadding="16dp"
                            app:iconTint="@color/app_primary_color" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/app_secondary_text_color" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:gravity="center_vertical|start"
                            android:text="CẬP NHẬT THÔNG TIN BỆNH NHÂN"
                            android:textColor="@color/app_primary_text_color"
                            app:icon="@drawable/dashboard_icon_report"
                            app:iconPadding="16dp"
                            app:iconTint="@color/app_primary_color" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/app_secondary_text_color" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:gravity="center_vertical|start"
                            android:text="QUẢN LÝ HÓA ĐƠN"
                            android:textColor="@color/app_primary_text_color"
                            app:icon="@drawable/dashboard_icon_report"
                            app:iconPadding="16dp"
                            app:iconTint="@color/app_primary_color" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/app_secondary_text_color" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>