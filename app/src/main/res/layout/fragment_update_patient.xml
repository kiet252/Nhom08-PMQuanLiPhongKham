<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập mã bệnh nhân hoặc CCCD để tìm"
        app:endIconMode="custom"
        app:endIconDrawable="@android:drawable/ic_menu_search">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtSearchPatient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/app_secondary_text_color"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/txtSearchError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Không tìm thấy thông tin bệnh nhân!"
        android:textColor="#F44336"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/layoutEditFields"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Thông tin cá nhân"
                android:textColor="@color/app_primary_text_color"
                android:textSize="20sp"
                android:textStyle="italic|bold" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Họ và tên (Cố định)"
                android:enabled="false"
                app:startIconDrawable="@drawable/userprofile_ic_name">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEditFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/app_secondary_text_color" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Ngày sinh (Cố định)"
                android:enabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEditBirthday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/app_secondary_text_color" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:textColor="@color/app_secondary_text_color"
                android:layout_marginVertical="16dp"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Địa chỉ"
                app:startIconDrawable="@drawable/userprofile_ic_address">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEditAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/app_secondary_text_color"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Số điện thoại"
                app:startIconDrawable="@drawable/userprofile_ic_phone">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEditPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="@color/app_secondary_text_color"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Giới tính:"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgEditGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton android:id="@+id/rbEditMale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nam" android:textColor="@color/app_primary_text_color"/>
                <RadioButton android:id="@+id/rbEditFemale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:text="Nữ" android:textColor="@color/app_primary_text_color" />
                <RadioButton android:id="@+id/rbEditOther" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:text="Khác" android:textColor="@color/app_primary_text_color" />
            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Cập nhật số CCCD">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEditCCCD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/app_secondary_text_color"/>
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>