<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/userprofile_ic_name"
            android:drawablePadding="10dp"
            android:drawableTint="#0D3F6E"
            android:gravity="center_vertical"
            android:text="TRA CỨU BỆNH NHÂN"
            android:textColor="#64748B"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="18dp"
            android:background="#E2E8F0" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilUpdatePatientSearchPatientLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập mã bệnh nhân hoặc CCCD để tìm"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusTopStart="14dp"
            app:endIconCheckable="true"
            app:endIconContentDescription="Search Button"
            app:endIconDrawable="@android:drawable/ic_menu_search"
            app:endIconTint="@color/app_primary_btn_color"
            app:endIconMode="custom">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtUpdatePatientSearchPatient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1E293B"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/txtSearchError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Không tìm thấy thông tin bệnh nhân!"
            android:textColor="#F44336"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutEditFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_edit_patient_info"
                android:drawablePadding="10dp"
                android:drawableTint="#0D3F6E"
                android:gravity="center_vertical"
                android:text="THÔNG TIN BỆNH NHÂN"
                android:textColor="#64748B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="18dp"
                android:background="#E2E8F0" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:hint="Họ và tên (Cố định)"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:startIconDrawable="@drawable/userprofile_ic_name"
                app:startIconTint="#E91E63">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtUpdatePatientFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#64748B"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:enabled="false"
                android:hint="Ngày sinh (Cố định)"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:startIconDrawable="@drawable/userprofile_ic_birthday"
                app:startIconTint="#9C27B0">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtUpdatePatientBirthday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#64748B"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Địa chỉ"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:startIconDrawable="@drawable/userprofile_ic_address"
                app:startIconTint="#FF9800">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtUpdatePatientAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#1E293B"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Số điện thoại"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:startIconDrawable="@drawable/userprofile_ic_phone"
                app:startIconTint="#4CAF50">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtUpdatePatientPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="#1E293B"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Giới tính"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="#F8FBFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#D6E6F8"
                app:strokeWidth="1dp">

                <RadioGroup
                    android:id="@+id/rgUpdatePatientGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <RadioButton
                        android:id="@+id/rbUpdatePatientMale"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="6dp"
                        android:text="Nam"
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        app:buttonTint="#0D3F6E" />

                    <RadioButton
                        android:id="@+id/rbUpdatePatientFemale"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="6dp"
                        android:text="Nữ"
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        app:buttonTint="#0D3F6E" />

                    <RadioButton
                        android:id="@+id/rbUpdatePatientOther"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="6dp"
                        android:text="Khác"
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        app:buttonTint="#0D3F6E" />
                </RadioGroup>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Cập nhật số CCCD"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtUpdatePatientCCCD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="#1E293B"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
