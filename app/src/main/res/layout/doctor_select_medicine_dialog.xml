<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_examination_form_details"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp">

        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_dot_yellow" />

        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_dot_pink" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CHỌN THUỐC"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnCloseMedicineDialog"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_exit_prescription"
            app:tint="#111827" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#D8E0EA" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMedicineList"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="14dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingHorizontal="14dp"
        android:paddingTop="6dp"
        android:paddingBottom="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmMedicineSelection"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:backgroundTint="#0D3F6E"
            android:text="Chọn"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="14dp"
            app:elevation="2dp" />
    </LinearLayout>
</LinearLayout>
