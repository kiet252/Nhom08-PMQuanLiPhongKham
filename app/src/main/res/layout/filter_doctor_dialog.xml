<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_dialog_white_rounded">

    <TextView
        android:id="@+id/tvFilterDoctorTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lọc theo bác sĩ"
        android:textColor="#222222"
        android:textSize="18sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/rgDoctorFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rbAllDoctors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:paddingVertical="8dp"
            android:text="Tất cả"
            android:textColor="#333333"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rbDoctor1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="BS Messi"
            android:textColor="#333333"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/rbDoctor3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="BS Trần Thị B"
            android:textColor="#333333"
            android:textSize="15sp" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelFilter"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hủy"
            android:textColor="#666666" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Áp dụng"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/app_primary_btn_color"
            app:cornerRadius="10dp" />
    </LinearLayout>

</LinearLayout>
