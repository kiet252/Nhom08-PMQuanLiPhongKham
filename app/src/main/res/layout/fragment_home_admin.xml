<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_home_admin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7FF"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context="dashboard_fragment.HomeFragment_admin">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:background="@drawable/bg_gradient_dark_blue">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chào mừng👋"
                        android:textColor="#B3FFFFFF"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/admin_home_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="name"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="66dp"
                    android:layout_height="66dp"
                    app:cardBackgroundColor="#26FFFFFF"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/home_avatar_admin"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                         />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </FrameLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="-25dp"
            android:layout_weight="9"
            app:cardBackgroundColor="#F0F7FF"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="30dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="40dp">

                    <!-- ViewPager giữ nguyên -->
                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/view_pager_admin_charts"
                        android:layout_width="match_parent"
                        android:layout_height="340dp"
                        android:layout_marginBottom="12dp" />

                    <!-- Indicators giữ nguyên -->
                    <LinearLayout
                        android:id="@+id/layout_chart_indicators"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="22dp"
                        android:orientation="horizontal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Chức năng chính"
                        android:textColor="#0D3F6E"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- Row 1: Nhân viên | Thuốc & CLS | Phân ca -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="7dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:id="@+id/btn_mngStaff"
                                android:layout_width="match_parent"
                                android:layout_height="130dp"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp"
                                android:clickable="true"
                                android:focusable="true">

                                <FrameLayout
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:background="@drawable/bg_rounded_cyan"
                                    android:layout_marginBottom="10dp">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/dashboard_icon_doctor"
                                        android:scaleType="fitCenter" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Quản lý\nNhân viên"
                                    android:textColor="#1E293B"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="7dp"
                            android:layout_marginEnd="7dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:id="@+id/btn_mngMedicineClinical"
                                android:layout_width="match_parent"
                                android:layout_height="130dp"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp"
                                android:clickable="true"
                                android:focusable="true">

                                <FrameLayout
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:background="@drawable/bg_rounded_purple"
                                    android:layout_marginBottom="10dp">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/dashboard_icon_clinical_medicine"
                                        android:scaleType="fitCenter" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Thuốc &amp;\nDịch vụ CLS"
                                    android:textColor="#1E293B"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="7dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:id="@+id/btn_mngTimekeepingSchedule"
                                android:layout_width="match_parent"
                                android:layout_height="130dp"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp"
                                android:clickable="true"
                                android:focusable="true">

                                <FrameLayout
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:background="@drawable/bg_rounded_navy"
                                    android:layout_marginBottom="10dp">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/dashboard_icon_assignment"
                                        android:scaleType="fitCenter" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Phân ca\nChấm công"
                                    android:textColor="#1E293B"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Row 2: Sửa chấm công | Duyệt thiết bị | Báo cáo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="7dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:id="@+id/btn_mngTimekeepingFixRequest"
                                android:layout_width="match_parent"
                                android:layout_height="130dp"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp"
                                android:clickable="true"
                                android:focusable="true">

                                <FrameLayout
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:background="@drawable/bg_rounded_blue"
                                    android:layout_marginBottom="10dp">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/dashboard_icon_request"
                                        android:scaleType="fitCenter" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Yêu cầu\nSửa Chấm công"
                                    android:textColor="#1E293B"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="7dp"
                            android:layout_marginEnd="7dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:id="@+id/btn_mngDeviceApproval"
                                android:layout_width="match_parent"
                                android:layout_height="130dp"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp"
                                android:clickable="true"
                                android:focusable="true">

                                <FrameLayout
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:background="@drawable/bg_rounded_amber"
                                    android:layout_marginBottom="10dp">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/dashboard_icon_smartphone"
                                        android:scaleType="fitCenter" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Duyệt Thiết bị &amp;\n khuôn mặt "
                                    android:textColor="#1E293B"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="7dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:id="@+id/btn_xem_bao_cao"
                                android:layout_width="match_parent"
                                android:layout_height="130dp"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp"
                                android:clickable="true"
                                android:focusable="true">

                                <FrameLayout
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:background="@drawable/bg_rounded_green"
                                    android:layout_marginBottom="10dp">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/dashboard_icon_report"
                                        android:scaleType="fitCenter" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Báo cáo &amp;\nThống kê"
                                    android:textColor="#1E293B"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Row 3: Thông báo + 2 spacer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="7dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:id="@+id/btn_cai_dat_thong_bao"
                                android:layout_width="match_parent"
                                android:layout_height="130dp"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp"
                                android:clickable="true"
                                android:focusable="true">

                                <FrameLayout
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:background="@drawable/bg_rounded_orange"
                                    android:layout_marginBottom="10dp">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/dashboard_icon_manage"
                                        android:scaleType="fitCenter" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Quản lí\nThông báo"
                                    android:textColor="#1E293B"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:gravity="center" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="7dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="18dp"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:id="@+id/btn_location_setting"
                                android:layout_width="match_parent"
                                android:layout_height="130dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <FrameLayout
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:layout_marginBottom="10dp"
                                    android:background="@drawable/bg_rounded_blue">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:scaleType="fitCenter"
                                        android:src="@drawable/ic_location" />
                                </FrameLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Cài đặt\nVị trí"
                                    android:textColor="#1E293B"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                        <View
                            android:layout_width="0dp"
                            android:layout_height="130dp"
                            android:layout_weight="1"
                            android:layout_marginStart="7dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <com.example.nhom08_quanlyphongkham.widget.ChatbotFloatingButton
        android:id="@+id/chatbot_floating_button"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="18dp"
        android:elevation="20dp" />

</FrameLayout>