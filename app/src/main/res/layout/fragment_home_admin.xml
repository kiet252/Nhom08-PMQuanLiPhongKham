<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_home_admin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7FF"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context="dashboard_fragment.HomeFragment_admin">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:background="@drawable/bg_gradient_dark_blue">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chào mừng👋"
                        android:textColor="#B3FFFFFF"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/admin_home_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="name"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="66dp"
                    android:layout_height="66dp"
                    app:cardBackgroundColor="#26FFFFFF"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/home_avatar_admin"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        android:src="@drawable/dashboard_icon_avatar" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </FrameLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="-25dp"
            android:layout_weight="9"
            app:cardBackgroundColor="#F0F7FF"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="30dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="40dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/view_pager_admin_charts"
                        android:layout_width="match_parent"
                        android:layout_height="340dp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:id="@+id/layout_chart_indicators"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="22dp"
                        android:orientation="horizontal" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Chức năng chính"
                        android:textColor="#0D3F6E"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="5dp"
                                android:layout_height="match_parent"
                                android:background="#14B8D4" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_mngStaff"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:gravity="center_vertical|start"
                                android:text="QUẢN LÝ THÔNG TIN NHÂN VIÊN"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                app:icon="@drawable/dashboard_icon_doctor"
                                app:iconPadding="16dp"
                                app:iconSize="42dp"
                                app:iconTint="@null" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="5dp"
                                android:layout_height="match_parent"
                                android:background="#9C27B0" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_mngMedicineClinical"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:gravity="center_vertical|start"
                                android:text="QUẢN LÝ THUỐC &amp; DỊCH VỤ CLS"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                app:icon="@drawable/dashboard_icon_manage"
                                app:iconPadding="16dp"
                                app:iconSize="42dp"
                                app:iconTint="@null" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="5dp"
                                android:layout_height="match_parent"
                                android:background="#0D3F6E" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_mngTimekeepingSchedule"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:gravity="center_vertical|start"
                                android:text="PHÂN CA CHẤM CÔNG"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                app:icon="@drawable/ic_clock"
                                app:iconPadding="16dp"
                                app:iconSize="42dp"
                                app:iconTint="#0D3F6E" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="5dp"
                                android:layout_height="match_parent"
                                android:background="#4569E8" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_mngTimekeepingFixRequest"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:gravity="center_vertical|start"
                                android:text="YÊU CẦU SỬA CHẤM CÔNG"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                app:icon="@drawable/ic_save"
                                app:iconPadding="16dp"
                                app:iconSize="42dp"
                                app:iconTint="#4569E8" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="5dp"
                                android:layout_height="match_parent"
                                android:background="#F2A900" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_mngDeviceApproval"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:gravity="center_vertical|start"
                                android:text="QUẢN LÝ DUYỆT THIẾT BỊ"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                app:icon="@drawable/ic_device_phone"
                                app:iconPadding="16dp"
                                app:iconSize="42dp"
                                app:iconTint="#0D3F6E" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>


                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="5dp"
                                android:layout_height="match_parent"
                                android:background="#4CAF50" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_xem_bao_cao"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:gravity="center_vertical|start"
                                android:text="XEM BÁO CÁO VÀ THỐNG KÊ"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                app:icon="@drawable/dashboard_icon_report"
                                app:iconPadding="16dp"
                                app:iconSize="42dp"
                                app:iconTint="@null" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="5dp"
                                android:layout_height="match_parent"
                                android:background="#E67E22" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_cai_dat_thong_bao"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:gravity="center_vertical|start"
                                android:text="QUẢN LÍ THÔNG BÁO"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                app:icon="@drawable/dashboard_icon_manage"
                                app:iconPadding="16dp"
                                app:iconSize="42dp"
                                app:iconTint="@null" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <com.example.nhom08_quanlyphongkham.widget.ChatbotFloatingButton
        android:id="@+id/chatbot_floating_button"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="18dp"
        android:elevation="20dp" />

</FrameLayout>
