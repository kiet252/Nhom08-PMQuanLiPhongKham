<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7FF"
    tools:context="dashboard_fragment.NotificationSettingsFragment_Admin">

    <LinearLayout
        android:id="@+id/layout_admin_notification_list_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/bg_gradient_dark_blue">

            <ImageButton
                android:id="@+id/btn_back_admin_notification"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Quay lại"
                android:padding="12dp"
                android:src="@drawable/ic_back_white"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Thông báo chung"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_add_admin_notification"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Tạo thông báo"
                android:gravity="center"
                android:text="+"
                android:textColor="#FFFFFF"
                android:textSize="34sp" />
        </FrameLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="-28dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_tab_da_gui_admin_notification"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Đã gửi"
                            android:textColor="#0D3F6E"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <View
                            android:id="@+id/line_tab_da_gui_admin_notification"
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:background="#1E90FF" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_tab_nhap_admin_notification"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Nháp"
                            android:textColor="#64748B"
                            android:textSize="15sp" />

                        <View
                            android:id="@+id/line_tab_nhap_admin_notification"
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:background="#1E90FF"
                            android:visibility="invisible" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_admin_notification_delete_actions"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:gravity="center_vertical|end"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <TextView
                        android:id="@+id/btn_select_admin_notification"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:minWidth="76dp"
                        android:background="@drawable/bg_light_gray_rounded"
                        android:backgroundTint="#E0F2FE"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Chọn"
                        android:textColor="#0D5FA8"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btn_delete_admin_notification"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginStart="10dp"
                        android:minWidth="76dp"
                        android:background="@drawable/bg_light_gray_rounded"
                        android:backgroundTint="#FEE2E2"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Xóa"
                        android:textColor="#DC2626"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="#F0F7FF">

                    <androidx.core.widget.NestedScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fillViewport="true">

                        <LinearLayout
                            android:id="@+id/layout_danh_sach_thong_bao_fragment_admin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="14dp"
                            android:paddingTop="22dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="32dp" />
                    </androidx.core.widget.NestedScrollView>

                    <TextView
                        android:id="@+id/tv_admin_notification_loading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:padding="24dp"
                        android:text="Đang tải thông báo..."
                        android:textColor="#64748B"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layout_admin_notification_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="28dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="108dp"
                            android:layout_height="108dp"
                            android:alpha="0.18"
                            android:contentDescription="Thông báo trống"
                            android:src="@drawable/ic_notification"
                            app:tint="#1E90FF" />

                        <TextView
                            android:id="@+id/tv_admin_notification_empty_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:gravity="center"
                            android:text="Chưa có thông báo nào"
                            android:textColor="#0F172A"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_admin_notification_empty_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Nhấn + để tạo thông báo mới"
                            android:textColor="#64748B"
                            android:textSize="15sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_admin_notification_create_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0F7FF"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/bg_gradient_dark_blue">

            <ImageButton
                android:id="@+id/btn_back_create_admin_notification"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Quay lại"
                android:padding="12dp"
                android:src="@drawable/ic_back_white"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Tạo thông báo chung"
                android:textColor="#FFFFFF"
                android:textSize="23sp"
                android:textStyle="bold" />
        </FrameLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="-28dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingTop="32dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="32dp">

                    <TextView
                        style="@style/TextAppearance.MaterialComponents.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiêu đề"
                        android:textColor="#0D3F6E"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edt_admin_notification_title"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:background="@drawable/bg_border_rounded"
                        android:hint="Nhập tiêu đề thông báo"
                        android:inputType="textCapSentences"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:singleLine="true"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp" />

                    <TextView
                        style="@style/TextAppearance.MaterialComponents.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nội dung"
                        android:textColor="#0D3F6E"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edt_admin_notification_content"
                        android:layout_width="match_parent"
                        android:layout_height="126dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:background="@drawable/bg_border_rounded"
                        android:gravity="top|start"
                        android:hint="Nhập nội dung thông báo"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="4"
                        android:padding="16dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp" />

                    <TextView
                        style="@style/TextAppearance.MaterialComponents.Body2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gửi đến"
                        android:textColor="#0D3F6E"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Chọn vai trò nhận thông báo"
                        android:textColor="#64748B"
                        android:textSize="13sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="28dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="2dp"
                        app:strokeColor="#E3EEF8"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="12dp"
                            android:paddingTop="8dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="8dp">

                            <CheckBox
                                android:id="@+id/cb_admin_notification_all"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:buttonTint="#1E90FF"
                                android:text="Tất cả&#10;Admin, Bác sĩ, Nhân viên"
                                android:textColor="#334155"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <CheckBox
                                android:id="@+id/cb_admin_notification_admin"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:buttonTint="#1E90FF"
                                android:text="Admin&#10;Chỉ gửi đến Admin"
                                android:textColor="#334155"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <CheckBox
                                android:id="@+id/cb_admin_notification_doctor"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:buttonTint="#1E90FF"
                                android:checked="true"
                                android:text="Bác sĩ&#10;Chỉ gửi đến Bác sĩ"
                                android:textColor="#334155"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <CheckBox
                                android:id="@+id/cb_admin_notification_receptionist"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:buttonTint="#1E90FF"
                                android:text="Nhân viên&#10;Chỉ gửi đến Nhân viên"
                                android:textColor="#334155"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_admin_notification_draft"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="12dp"
                        android:text="Vào bản nháp"
                        android:textAllCaps="false"
                        android:textColor="#0D5FA8"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="#E0F2FE"
                        app:cornerRadius="14dp"
                        app:strokeColor="#B7DDF8"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_admin_notification_send"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Gửi thông báo"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="#0D5FA8"
                        app:cornerRadius="14dp" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</FrameLayout>
