<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_edit_profile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F7FF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_dark_blue_header"
        android:paddingBottom="20dp">

        <ImageButton
            android:id="@+id/btnBackEditProfile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tvEditProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Chỉnh sửa hồ sơ"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBackEditProfile"
            app:layout_constraintStart_toEndOf="@id/btnBackEditProfile"
            app:layout_constraintTop_toTopOf="@id/btnBackEditProfile" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:foregroundGravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEditProfileAvatar"
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:layout_gravity="center"
                    app:cardBackgroundColor="#DFF1FF"
                    app:cardCornerRadius="52dp"
                    app:cardElevation="3dp">

                    <ImageView
                        android:id="@+id/imgEditProfileAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/dashboard_icon_avatar" />
                </androidx.cardview.widget.CardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnChangeAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center_horizontal|bottom"
                    android:layout_marginStart="72dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#0D3F6E"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_edit_profile"
                        app:tint="@android:color/white" />
                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:text="Đổi ảnh đại diện"
                android:textColor="#64748B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THÔNG TIN CÁ NHÂN"
                        android:textColor="#64748B"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="18dp"
                        android:background="#E2E8F0" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Họ tên"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:startIconDrawable="@drawable/userprofile_ic_name"
                        app:startIconTint="#E91E63">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtEditProfileFullName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:text="Nguyễn Văn A"
                            android:textColor="#1E293B"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>


                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Email (cố định)"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:startIconDrawable="@drawable/userprofile_ic_email"
                        app:startIconTint="#00BCD4">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtEditProfileEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:enabled="false"
                            android:text="example@gmail.com"
                            android:textColor="#64748B"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>


                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Ngày sinh (cố đinh)"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:startIconDrawable="@drawable/userprofile_ic_birthday"
                        app:startIconTint="#9C27B0">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtEditProfileBirthday"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:enabled="false"
                            android:text="01/01/2000"
                            android:textColor="#64748B"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>


                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Số điện thoại"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:startIconDrawable="@drawable/userprofile_ic_phone"
                        app:startIconTint="#4CAF50">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtEditProfilePhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:text="0901234567"
                            android:textColor="#1E293B"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>


                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:hint="Địa chỉ"
                        app:boxCornerRadiusBottomEnd="14dp"
                        app:boxCornerRadiusBottomStart="14dp"
                        app:boxCornerRadiusTopEnd="14dp"
                        app:boxCornerRadiusTopStart="14dp"
                        app:startIconDrawable="@drawable/userprofile_ic_address"
                        app:startIconTint="#FF9800">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtEditProfileAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:text="123 Nguyễn Huệ, Quận 1, TP.HCM"
                            android:textColor="#1E293B"
                            android:textSize="16sp" />
                    </com.google.android.material.textfield.TextInputLayout>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Giới tính"
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardBackgroundColor="#F8FBFF"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#D6E6F8"
                        app:strokeWidth="1dp">

                        <RadioGroup
                            android:id="@+id/rgEditProfileGender"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <RadioButton
                                android:id="@+id/rbGenderMale"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingVertical="6dp"
                                android:text="Nam"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                app:buttonTint="#0D3F6E"/>

                            <RadioButton
                                android:id="@+id/rbGenderFemale"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingVertical="6dp"
                                android:text="Nữ"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                app:buttonTint="#0D3F6E"/>

                            <RadioButton
                                android:id="@+id/rbGenderOther"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingVertical="6dp"
                                android:text="Khác"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                app:buttonTint="#0D3F6E"/>
                        </RadioGroup>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="10dp"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveEditProfile"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="LƯU THAY ĐỔI"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#0D3F6E"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_edit_profile"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconTint="@android:color/white" />

    </LinearLayout>

</LinearLayout>
