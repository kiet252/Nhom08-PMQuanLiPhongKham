<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:background="#DFF6FB"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tvMedicineIndex"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:text="1"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_count_badge_selected" />

            <TextView
                android:id="@+id/tvSelectedMedicineName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Amoxicillin 500mg"
                android:textColor="#0D3F6E"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSelectedMedicineStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TK: 500 viên"
                android:textColor="#0D3F6E"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnRemoveMedicine"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_delete"
                app:tint="#FF6B6B" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIỀU DÙNG"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtSelectedDose"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_prescription_field"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:text="1 viên"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GHI CHÚ"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtSelectedNote"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_prescription_field"
                    android:gravity="center_vertical"
                    android:hint="Uống sau ăn..."
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:textColor="#1E293B"
                    android:textColorHint="#94A3B8"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TẦN SUẤT"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <AutoCompleteTextView
                    android:id="@+id/spinnerSelectedFrequency"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_prescription_field"
                    android:clickable="true"
                    android:drawableEnd="@drawable/ic_chevron_down"
                    android:focusable="true"
                    android:cursorVisible="false"
                    android:inputType="none"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:text="2 lần/ngày"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THỜI GIAN"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <AutoCompleteTextView
                    android:id="@+id/spinnerSelectedDuration"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_prescription_field"
                    android:clickable="true"
                    android:drawableEnd="@drawable/ic_chevron_down"
                    android:focusable="true"
                    android:cursorVisible="false"
                    android:inputType="none"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:text="7 ngày"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>


    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
