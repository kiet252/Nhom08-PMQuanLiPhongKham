<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    tools:context="dashboard_fragment.ReportsFragment_Admin">

    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/gradient_blue_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_scrollFlags="scroll|enterAlways"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="220dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">



            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/et_ma_hoa_don"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_border_rounded"
                            android:hint="Mã hóa đơn..."
                            android:paddingHorizontal="12dp"
                            android:textSize="14sp"
                            android:singleLine="true"/>

                        <EditText
                            android:id="@+id/et_ten_benh_nhan"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_border_rounded"
                            android:hint="Tên bệnh nhân..."
                            android:paddingHorizontal="12dp"
                            android:textSize="14sp"
                            android:singleLine="true"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_tu_ngay"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_border_rounded"
                            android:gravity="center_vertical"
                            android:hint="Từ ngày"
                            android:paddingHorizontal="12dp"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp"
                            app:drawableStartCompat="@drawable/ic_calendar"
                            android:drawablePadding="8dp"/>

                        <TextView
                            android:id="@+id/tv_den_ngay"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_border_rounded"
                            android:gravity="center_vertical"
                            android:hint="Đến ngày"
                            android:paddingHorizontal="12dp"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp"
                            app:drawableStartCompat="@drawable/ic_calendar"
                            android:drawablePadding="8dp"/>

                        <Button
                            android:id="@+id/btn_tim_kiem"
                            android:layout_width="wrap_content"
                            android:layout_height="54dp"
                            android:backgroundTint="#4A81B0"
                            android:text="Tìm kiếm"
                            android:textColor="#FFFFFF"
                            app:cornerRadius="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FAFAFA"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tv_tong_so_hoa_don"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số hóa đơn: 0"
                            android:textColor="#333333"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"/>

                        <TextView
                            android:id="@+id/tv_tong_doanh_thu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng doanh thu: 0 đ"
                            android:textColor="#D9534F"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:background="#FFFFFF">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mã ĐK"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="#555555"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ngày khám"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="#555555"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.5"
                            android:text="Bệnh nhân"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="#555555"
                            android:gravity="center"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.5"
                            android:text="Tổng tiền"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="#555555"
                            android:gravity="center"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:background="#FAFAFA">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_danh_sach_doanh_thu"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_empty_state"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="Không tồn tại hóa đơn nào!"
                            android:textColor="#D98C72"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>